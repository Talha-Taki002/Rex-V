// Assembly Code            // Expected Result (in Decimal)
00500093                    // addi x1, x0, 5    --> x1 = 5
00a00113                    // addi x2, x0, 10   --> x2 = 10
002081b3                    // add  x3, x1, x2   --> x3 = 15
40110233                    // sub  x4, x2, x1   --> x4 = 5
0020f2b3                    // and  x5, x1, x2   --> x5 = 0  (0101 & 1010)
0020e333                    // or   x6, x1, x2   --> x6 = 15 (0101 | 1010)
0020a3b3                    // slt  x7, x1, x2   --> x7 = 1  (5 < 10 is true)
0010a433                    // slt  x8, x2, x1   --> x8 = 0  (10 < 5 is false)
00000063                    // beq  x0, x0, 0    --> Infinite loop (Halt)