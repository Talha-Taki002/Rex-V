// Phase 1: Arithmetic & Logic Verification
03200093 // addi x1, x0, 50      (x1 = 50)
01900113 // addi x2, x0, 25      (x2 = 25)
002081b3 // add  x3, x1, x2      (x3 = 50 + 25 = 75)
40208233 // sub  x4, x1, x2      (x4 = 50 - 25 = 25)
0041f2b3 // and  x5, x3, x4      (x5 = 75 & 25 = 9)
0041e333 // or   x6, x3, x4      (x6 = 75 | 25 = 91)
003223b3 // slt  x7, x4, x3      (x7 = 25 < 75 = 1)

// Phase 2: Memory Integrity
02800413 // addi x8, x0, 40      (x8 = Base Address 40)
00642023 // sw   x6, 0(x8)       (Store 91 into Memory[40])
00042483 // lw   x9, 0(x8)       (Load 91 back into x9)

// Phase 3: Software Multiplication (Branching & Jumping)
// We will multiply x7 (1) by x9 (91) using a loop. Result goes to x10.
00000513 // addi x10, x0, 0      (x10 = Result = 0)
00100593 // addi x11, x0, 1      (x11 = Loop Decrementer = 1)
// MULT_LOOP: (PC = 0x30)
00048863 // beq  x9, x0, 16      (If x9 == 0, jump out of loop to MULT_END)
00750533 // add  x10, x10, x7    (x10 = x10 + 1)
40b484b3 // sub  x9, x9, x11     (x9 = x9 - 1)
ff5ff06f // jal  x0, -12         (Jump back to MULT_LOOP)

// Phase 4: Self-Checking
// MULT_END: (PC = 0x40)
05b00613 // addi x12, x0, 91     (Expected correct answer)
00c50463 // beq  x10, x12, 8     (If our loop calculated 91, jump to PASS)
0100006f // jal  x0, 16          (Math was wrong! Jump to FAIL)

// PASS: (PC = 0x4C)
7ea00f93 // addi x31, x0, 2026   (Load the Victory Code!)
06400f13 // addi x30, x0, 100    (Load target memory address)
01ff2023 // sw   x31, 0(x30)     (Write 2026 to DataMemory[100])

// FAIL / HALT: (PC = 0x58)
00000063 // beq  x0, x0, 0       (Infinite loop to end the simulation)